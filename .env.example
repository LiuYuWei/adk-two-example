# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in ONE of the two auth options below.
#   cp .env.example .env
# `.env` is git-ignored and is auto-loaded by `adk web` / `adk run`.
# ─────────────────────────────────────────────────────────────────────────────

# Model used by every agent in the workflow (overridable).
ADK_MODEL=gemini-2.5-flash

# ── Option A: Google AI Studio (simplest — just an API key) ──────────────────
# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-ai-studio-api-key-here

# ── Option B: Vertex AI (comment out Option A, uncomment these) ──────────────
# GOOGLE_GENAI_USE_VERTEXAI=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
